{
  "name": "hopefest-picture",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "migrate": "tsx node_modules/.bin/knex migrate:latest",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "turbo": "^2.4.4",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "tsx": "^4.21.0"
  }
}
